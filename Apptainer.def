Bootstrap: docker
From: ubuntu:22.04

%labels
    Author numeric-planneRS
    Description numeric-planneRS legacy canonical domain-abstraction planner
    PlannerGitRepository https://github.com/mrlab-ai/numeric_planneRS.git
    PlannerGitCommit 23a2a32bbd6c8018a7b31c510f6d9d7ec2f201ce

%environment
    export PATH=/opt/planner/bin:/opt/cargo/bin:$PATH
    export RUSTUP_HOME=/opt/rustup
    export CARGO_HOME=/opt/cargo
    export RUST_BACKTRACE=1
    export SEARCH_CONFIG='astar(canonical_domain_abstractions(blacklist_trigger_percentage=0.6,total_max_time=700,flaw_treatment=max_refined_single_atom,numeric_split_strategy=standard,flaw_kind=sequence_progression,use_wildcard_plans=true,combine_labels=true,max_abstraction_size=100000,max_collection_size=1000000))'

%setup
    set -eu

    ROOTFS="${APPTAINER_ROOTFS:-${SINGULARITY_ROOTFS:?}}"
    PLANNER_GIT_COMMIT=23a2a32bbd6c8018a7b31c510f6d9d7ec2f201ce

    mkdir -p "$ROOTFS/opt/src"
    git archive --format=tar "$PLANNER_GIT_COMMIT" | tar -x -C "$ROOTFS/opt/src"

%post
    set -eux

    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        build-essential \
        pkg-config
    rm -rf /var/lib/apt/lists/*

    export RUSTUP_HOME=/opt/rustup
    export CARGO_HOME=/opt/cargo
    export PATH=/opt/cargo/bin:$PATH

    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs \
        | sh -s -- -y --profile minimal --default-toolchain stable
    rustup update stable
    rustup default stable

    cd /opt/src
    cargo build --release --locked --bin planners

    install -Dm755 target/release/planners /opt/planner/bin/planners
    strip /opt/planner/bin/planners || true

    rm -rf /opt/cargo/registry /opt/cargo/git /opt/src/target

%runscript
    set -eu

    if [ "$#" -lt 2 ]; then
        echo "usage: apptainer run numeric-planners.sif DOMAIN.PDDL PROBLEM.PDDL [planner options]" >&2
        echo "override the default search with: apptainer run --env SEARCH_CONFIG='astar(...)' numeric-planners.sif DOMAIN.PDDL PROBLEM.PDDL" >&2
        exit 2
    fi

    DOMAIN=$(realpath "$1")
    PROBLEM=$(realpath "$2")
    shift 2

    RUN_DIR=$(mktemp -d "${TMPDIR:-/tmp}/numeric-planners.XXXXXX")
    cleanup() {
        rm -rf "$RUN_DIR"
    }
    trap cleanup EXIT INT TERM

    cd "$RUN_DIR"

    set +e
    /opt/planner/bin/planners --search "$SEARCH_CONFIG" "$@" "$DOMAIN" "$PROBLEM"
    STATUS=$?
    set -e

    exit "$STATUS"
